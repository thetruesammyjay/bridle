# Solana Configuration
SOLANA_RPC_URL=https://api.devnet.solana.com

# Gemini AI API Key (get one at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model (options: gemini-2.5-flash-lite, gemini-2.5-flash, gemini-3-flash, gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-flash-lite

# Encryption password for wallet key storage (use a strong random password)
ENCRYPTION_PASSWORD=change-this-to-a-strong-random-password

# Server port
PORT=3000

# Agent loop interval in milliseconds (default: 30 seconds)
AGENT_INTERVAL_MS=30000

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
